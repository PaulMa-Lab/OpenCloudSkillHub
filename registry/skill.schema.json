{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencloudskill.dev/schemas/skill.schema.json",
  "title": "OpenCloudSkillHub Skill Package Manifest",
  "description": "Structural (schema-level) contract for skill.yaml. Covers R-STRUCT-* and parts of R-REF/R-SAFE that are expressible in JSON Schema. Filesystem-existence (R-REF-*), guide<->script consistency (R-CONS-1), risk cross-check (R-SAFE-1), and governance (R-GOV-*) rules are enforced by validate_skill_package beyond this schema. See docs/skill-package-contract.md.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "summary",
    "maintainer",
    "capabilities",
    "risk_level",
    "platforms",
    "tools_required",
    "resources",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1"],
      "description": "Contract version this manifest targets."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Globally unique skill id (slug). Catalog primary key."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-.]+)?(?:\\+[0-9A-Za-z-.]+)?$",
      "description": "Semantic version."
    },
    "summary": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "maintainer": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "contact": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        }
      ]
    },
    "source": { "type": "string", "format": "uri" },
    "license": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]*$" }
    },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["windows", "macos", "linux"] }
    },
    "tools_required": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "file_read",
          "file_write",
          "shell_optional",
          "shell_required",
          "network_outbound",
          "model_download"
        ]
      }
    },
    "resources": {
      "type": "object",
      "required": ["guide"],
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/relPath" },
      "properties": { "guide": { "$ref": "#/$defs/relPath" } }
    },
    "install": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["guide"],
        "additionalProperties": false,
        "properties": {
          "guide": { "$ref": "#/$defs/relPath" },
          "default_profile": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
        }
      },
      "propertyNames": { "enum": ["windows", "macos", "linux"] }
    },
    "install_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "platforms"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "platforms": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["windows", "macos", "linux"] }
          },
          "requirements": { "type": "array", "items": { "$ref": "#/$defs/relPath" } },
          "creates_venv": { "type": "boolean" },
          "est_download_mb": { "type": "number", "minimum": 0 },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "notes": { "type": "string" }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["smoke_test"],
      "additionalProperties": false,
      "properties": {
        "smoke_test": { "$ref": "#/$defs/relPath" },
        "plan": { "$ref": "#/$defs/relPath" },
        "expected": {}
      }
    },
    "troubleshooting": { "$ref": "#/$defs/relPath" },
    "diagnostics": { "$ref": "#/$defs/relPath" },
    "recipes": { "$ref": "#/$defs/relPath" },
    "safety": { "$ref": "#/$defs/relPath" },
    "success_criteria": { "type": "object" },
    "requires_skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version_range"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "version_range": { "type": "string" }
        }
      }
    },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] }
  },
  "$defs": {
    "relPath": {
      "type": "string",
      "minLength": 1,
      "description": "Package-relative path. Absolute paths and '..' traversal are forbidden and reported as R-REF-2 by validate_skill_package (kept out of the schema so traversal yields one clear finding, not a regex error)."
    }
  }
}
