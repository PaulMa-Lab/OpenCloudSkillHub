[Unit]
Description=OpenCloudSkillHub MCP server (streamable-http)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/opencloudskillhub
EnvironmentFile=/opt/opencloudskillhub/deploy/ocsh.env
ExecStart=/opt/opencloudskillhub/.venv/bin/python -m opencloudskillhub.server --http
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
