# Copy to deploy/ocsh.env on the server and edit. Referenced by the systemd unit.
# (ocsh.env itself is gitignored — it may hold the admin token.)

OCSH_HOME=/opt/opencloudskillhub
OCSH_HOST=0.0.0.0
OCSH_PORT=8848

# Token store (issued agent tokens; gitignored). Default is <OCSH_HOME>/registry/tokens.json.
OCSH_TOKENS_FILE=/opt/opencloudskillhub/registry/tokens.json

# Auth on by default. Set to "off" to run fully open (NOT recommended even for tests).
# OCSH_AUTH=on

# Optional static ops token (always valid; for revoke/inspect tooling). Keep secret.
# OCSH_ADMIN_TOKEN=replace-with-a-long-random-string
